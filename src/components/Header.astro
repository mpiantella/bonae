---
import type { Translations } from '../i18n/es';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const base = t.lang === 'en' ? '/en/' : '/';
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-cream shadow-sm">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <a href={base} class="flex items-center gap-2 group" aria-label={t.siteName}>
      <div class="w-9 h-9 rounded-lg bg-dark-blue flex items-center justify-center shadow-sm group-hover:bg-dark-blue-dark transition-colors">
        <span class="text-terracotta font-bold text-lg leading-none">N</span>
      </div>
      <span class="font-bold text-dark-blue text-xl tracking-tight">BONAE TECH</span>
    </a>

    <div class="hidden md:flex items-center gap-6">
      <a href={`${base}#propuesta-valor`} class="text-sm font-medium text-pacificblue hover:text-dark-blue transition-colors">{t.nav.home}</a>
      <a href={`${base}#nosotras`} class="text-sm font-medium text-pacificblue hover:text-dark-blue transition-colors">{t.nav.about}</a>
      <a href={`${base}#servicios`} class="text-sm font-medium text-pacificblue hover:text-dark-blue transition-colors">{t.nav.services}</a>
      <a href={`${base}#portafolio`} class="text-sm font-medium text-pacificblue hover:text-dark-blue transition-colors">{t.nav.portfolio}</a>
      <a href={`${base}#blog`} class="text-sm font-medium text-pacificblue hover:text-dark-blue transition-colors">{t.nav.blog}</a>
      <a href={`${base}#contacto`} class="text-sm font-medium text-pacificblue hover:text-dark-blue transition-colors">{t.nav.contact}</a>
      <a
        href={`${base}#contacto`}
        class="btn-primary text-sm py-2 px-4"
      >
        {t.nav.cta}
      </a>
      <a
        href={t.nav.langSwitchHref}
        class="text-xs font-semibold px-3 py-1.5 rounded-full border border-light-blue/30 text-dark-blue hover:bg-cream transition-colors"
        aria-label={t.lang === 'en' ? 'Cambiar a Español' : 'Switch to English'}
      >
        {t.nav.langSwitch}
      </a>
    </div>

    <div class="flex md:hidden items-center gap-3">
      <a href={t.nav.langSwitchHref} class="text-xs font-semibold px-2.5 py-1 rounded-full border border-light-blue/30 text-dark-blue">
        {t.nav.langSwitch}
      </a>
      <label for="mobile-menu-toggle" class="cursor-pointer p-1" aria-label="Menu">
        <svg class="w-6 h-6 text-dark-blue" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </label>
    </div>
  </nav>

  <input type="checkbox" id="mobile-menu-toggle" class="hidden peer" />
  <div class="hidden peer-checked:block md:hidden border-t border-cream bg-white px-4 py-4 space-y-3">
    <a href={`${base}#propuesta-valor`} class="block text-sm font-medium text-pacificblue hover:text-dark-blue py-1">{t.nav.home}</a>
    <a href={`${base}#nosotras`} class="block text-sm font-medium text-pacificblue hover:text-dark-blue py-1">{t.nav.about}</a>
    <a href={`${base}#servicios`} class="block text-sm font-medium text-pacificblue hover:text-dark-blue py-1">{t.nav.services}</a>
    <a href={`${base}#portafolio`} class="block text-sm font-medium text-pacificblue hover:text-dark-blue py-1">{t.nav.portfolio}</a>
    <a href={`${base}#blog`} class="block text-sm font-medium text-pacificblue hover:text-dark-blue py-1">{t.nav.blog}</a>
    <a href={`${base}#contacto`} class="block text-sm font-medium text-pacificblue hover:text-dark-blue py-1">{t.nav.contact}</a>
    <a href={`${base}#contacto`} class="block btn-primary text-center py-2 mt-2">{t.nav.cta}</a>
  </div>
</header>
