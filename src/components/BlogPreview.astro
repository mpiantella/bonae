---
import type { Translations } from '../i18n/es';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const base = t.lang === 'en' ? '/en/' : '/';
---

<section id="blog" class="py-20 bg-slate-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14">
      <span class="inline-block px-3 py-1 rounded-full bg-navy-50 text-navy-600 text-xs font-semibold uppercase tracking-wider mb-4 border border-navy-100">
        {t.nav.blog}
      </span>
      <h2 class="section-title">
        {t.lang === 'en' ? 'Blog & Resources' : 'Blog y Recursos'}
      </h2>
      <p class="section-subtitle">
        {t.lang === 'en'
          ? 'Tips, guides, and updates for Latin American SMEs.'
          : 'Consejos, guías y actualizaciones para PyMEs latinoamericanas.'}
      </p>
    </div>

    <div class="card max-w-2xl mx-auto text-center py-12 px-6">
      <p class="text-slate-600 mb-4">
        {t.lang === 'en'
          ? 'Articles and downloadable resources coming soon.'
          : 'Artículos y recursos descargables próximamente.'}
      </p>
    </div>
  </div>
</section>
