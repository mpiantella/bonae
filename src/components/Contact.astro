---
import type { Translations } from '../i18n/es';

interface Props {
  t: Translations;
  whatsappHref: string;
}

const { t, whatsappHref } = Astro.props;
---

<section id="contacto" class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14">
      <span class="inline-block px-3 py-1 rounded-full bg-navy-50 text-navy-600 text-xs font-semibold uppercase tracking-wider mb-4 border border-navy-100">
        {t.contact.sectionBadge}
      </span>
      <h2 class="section-title">{t.contact.title}</h2>
      <p class="section-subtitle mb-10">{t.contact.subtitle}</p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12">
      <!-- Form -->
      <div class="card">
        <form
          action="/api/contact"
          method="POST"
          class="space-y-4"
          id="contact-form"
        >
          <input type="hidden" name="form-name" value="contact" />
          <div>
            <label for="name" class="block text-sm font-medium text-slate-700 mb-1">
              {t.contact.form.name} *
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-2 rounded-lg border border-slate-200 focus:border-navy-500 focus:ring-1 focus:ring-navy-500 outline-none transition-colors"
              autocomplete="name"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-slate-700 mb-1">
              {t.contact.form.email} *
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-2 rounded-lg border border-slate-200 focus:border-navy-500 focus:ring-1 focus:ring-navy-500 outline-none transition-colors"
              autocomplete="email"
            />
          </div>
          <div>
            <label for="phone" class="block text-sm font-medium text-slate-700 mb-1">
              {t.contact.form.phone} *
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              required
              class="w-full px-4 py-2 rounded-lg border border-slate-200 focus:border-navy-500 focus:ring-1 focus:ring-navy-500 outline-none transition-colors"
              autocomplete="tel"
            />
          </div>
          <div>
            <label for="business" class="block text-sm font-medium text-slate-700 mb-1">
              {t.contact.form.business}
            </label>
            <input
              type="text"
              id="business"
              name="business"
              class="w-full px-4 py-2 rounded-lg border border-slate-200 focus:border-navy-500 focus:ring-1 focus:ring-navy-500 outline-none transition-colors"
              autocomplete="organization"
            />
          </div>
          <div>
            <label for="service" class="block text-sm font-medium text-slate-700 mb-1">
              {t.contact.form.serviceType}
            </label>
            <select
              id="service"
              name="service"
              class="w-full px-4 py-2 rounded-lg border border-slate-200 focus:border-navy-500 focus:ring-1 focus:ring-navy-500 outline-none transition-colors bg-white"
            >
              <option value="">—</option>
              {t.contact.form.serviceOptions.map((opt) => (
                <option value={opt}>{opt}</option>
              ))}
            </select>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-slate-700 mb-1">
              {t.contact.form.message} *
            </label>
            <textarea
              id="message"
              name="message"
              rows={4}
              required
              class="w-full px-4 py-2 rounded-lg border border-slate-200 focus:border-navy-500 focus:ring-1 focus:ring-navy-500 outline-none transition-colors resize-none"
            ></textarea>
          </div>
          <button type="submit" class="btn-primary w-full justify-center">
            {t.contact.form.submit}
          </button>
        </form>
        <p class="mt-4 text-xs text-slate-500">
          {t.lang === 'en'
            ? 'Form submits to /api/contact. Add a Cloudflare Pages Function to handle submissions.'
            : 'El formulario envía a /api/contact. Añade una Cloudflare Pages Function para procesar los envíos.'}
        </p>
      </div>

      <!-- Contact info & social -->
      <div>
        <div class="card mb-6">
          <h3 class="font-bold text-navy-600 mb-4">{t.contact.whatsappText}</h3>
          <a
            href={whatsappHref}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-whatsapp inline-flex w-full justify-center mb-4"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp
          </a>
          <p class="text-sm text-slate-600">
            <a href={`mailto:${t.contact.email}`} class="text-navy-600 font-medium hover:underline">
              {t.contact.email}
            </a>
          </p>
          <p class="text-sm text-slate-600 mt-1">
            <a href={`https://wa.me/584140000000`} class="text-navy-600 font-medium hover:underline">
              {t.contact.phone}
            </a>
          </p>
          <p class="text-sm text-slate-500 mt-2">{t.contact.hours}</p>
        </div>

        <div class="card">
          <h3 class="font-bold text-navy-600 mb-2">{t.contact.location}</h3>
          <p class="text-sm text-slate-600">{t.contact.locationNote}</p>
        </div>

        <div class="mt-6 flex gap-4">
          <a href="https://wa.me/584140000000" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-lg bg-[#25D366] text-white flex items-center justify-center hover:opacity-90 transition-opacity" aria-label="WhatsApp">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </a>
          <a href="#" class="w-10 h-10 rounded-lg bg-[#E4405F] text-white flex items-center justify-center hover:opacity-90 transition-opacity" aria-label="Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          <a href="#" class="w-10 h-10 rounded-lg bg-[#1877F2] text-white flex items-center justify-center hover:opacity-90 transition-opacity" aria-label="Facebook">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="#" class="w-10 h-10 rounded-lg bg-[#0A66C2] text-white flex items-center justify-center hover:opacity-90 transition-opacity" aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
