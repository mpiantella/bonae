---
import type { Translations } from '../i18n/es';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="testimonios" class="py-20 bg-slate-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14">
      <span class="inline-block px-3 py-1 rounded-full bg-navy-50 text-navy-600 text-xs font-semibold uppercase tracking-wider mb-4 border border-navy-100">
        {t.testimonials.sectionBadge}
      </span>
      <h2 class="section-title">{t.testimonials.title}</h2>
      <p class="section-subtitle">{t.testimonials.subtitle}</p>
    </div>

    <div class="card max-w-2xl mx-auto text-center py-12 px-6">
      <p class="text-slate-600">{t.testimonials.comingSoon}</p>
    </div>
  </div>
</section>
