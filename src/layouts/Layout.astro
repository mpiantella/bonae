---
import '../styles/global.css';
import type { Translations } from '../i18n/es';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const whatsappHref = `https://wa.me/584140000000?text=${encodeURIComponent(t.contact.whatsappMessage)}`;
const isEn = t.lang === 'en';
const canonicalES = Astro.site ? new URL('/', Astro.site).href : '/';
const canonicalEN = Astro.site ? new URL('/en/', Astro.site).href : '/en/';
---

<!doctype html>
<html lang={t.lang} class="scroll-smooth" translate="no">
  <head>
    <meta charset="UTF-8" />
    <meta name="google" content="notranslate" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={t.metaDescription} />
    <meta name="theme-color" content="#1E3A5F" />

    <!-- Hreflang for bilingual SEO -->
    <link rel="alternate" hreflang="es" href={canonicalES} />
    <link rel="alternate" hreflang="en" href={canonicalEN} />
    <link rel="alternate" hreflang="x-default" href={canonicalES} />

    <!-- PWA manifest -->
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${t.siteName} — ${t.siteTagline}`} />
    <meta property="og:description" content={t.metaDescription} />
    <meta property="og:locale" content={isEn ? 'en_US' : 'es_VE'} />

    <title>{t.siteName} — {t.siteTagline}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <slot />
    <WhatsAppFloat href={whatsappHref} />
    <CookieBanner t={t} />
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js');
        });
      }
    </script>
  </body>
</html>
