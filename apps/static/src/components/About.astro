---
import type { Translations } from '../i18n/es';

interface Props {
  t: Translations;
}

const { t } = Astro.props;

const avatarColors = [
  'from-dark-blue to-dark-blue-dark',
  'from-mid-blue to-dark-blue',
  'from-terracotta to-terracotta-dark',
];
---

<section id="nosotras" class="py-20 bg-cream">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14">
      <span class="inline-block px-3 py-1 rounded-full bg-white text-dark-blue text-xs font-semibold uppercase tracking-wider mb-4 border border-light-blue/20">
        {t.about.sectionBadge}
      </span>
      <h2 class="section-title">{t.about.title}</h2>
    </div>

    <div class="space-y-12 mb-16">
      <div class="card max-w-3xl mx-auto">
        <h3 class="text-lg font-bold text-dark-blue mb-3">{t.about.history.title}</h3>
        <p class="text-pacificblue leading-relaxed">{t.about.history.content}</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="card">
          <h3 class="text-lg font-bold text-dark-blue mb-3">{t.about.mission.title}</h3>
          <p class="text-pacificblue leading-relaxed">{t.about.mission.content}</p>
        </div>
        <div class="card">
          <h3 class="text-lg font-bold text-dark-blue mb-3">{t.about.vision.title}</h3>
          <p class="text-pacificblue leading-relaxed">{t.about.vision.content}</p>
        </div>
      </div>

      <div class="card max-w-3xl mx-auto">
        <h3 class="text-lg font-bold text-dark-blue mb-4">{t.about.values.title}</h3>
        <ul class="space-y-2">
          {t.about.values.items.map((v) => (
            <li class="flex items-start gap-2 text-pacificblue">
              <span class="w-1.5 h-1.5 rounded-full bg-terracotta flex-shrink-0 mt-2"></span>
              {v}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <h3 class="text-xl font-bold text-dark-blue text-center mb-10">
      {t.lang === 'en' ? 'Founders' : 'Cofundadoras'}
    </h3>
    <div class="grid md:grid-cols-3 gap-6">
      {t.about.members.map((member, i) => (
        <article class="card text-center group">
          <div class={`w-20 h-20 rounded-2xl bg-gradient-to-br ${avatarColors[i]} flex items-center justify-center mx-auto mb-5 shadow-md`}>
            <span class="text-2xl font-bold text-white">{member.initials}</span>
          </div>
          <div class="text-xs font-semibold text-terracotta uppercase tracking-wider mb-2">
            {member.role}
          </div>
          <p class="text-sm text-pacificblue leading-relaxed mb-5">{member.bio}</p>
          <div class="flex flex-col gap-2">
            {member.highlights.map((h) => (
              <div class="flex items-center justify-center gap-2 text-xs text-pacificblue">
                <span class="w-1.5 h-1.5 rounded-full bg-terracotta flex-shrink-0"></span>
                {h}
              </div>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
