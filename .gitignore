apps/static/src/i18n/generated/*.merged.ts

# AWS CDK (infra/)
cdk.out/

# Astro internals
.astro/

# OS
.DS_Store

# Env
.env
.env.*
!.env.example
.cursor/

# Cloudflare Workers (local Wrangler secrets)
workers/**/.dev.vars
